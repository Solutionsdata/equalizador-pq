# Copie este arquivo para .env e preencha os valores

# Banco de dados (Neon — copie a connection string do painel)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# JWT — gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-longa

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# URL do frontend em producao (ex: https://seu-app.vercel.app)
FRONTEND_URL=https://seu-app.vercel.app
